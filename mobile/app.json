{
  "expo": {
    "name": "Vibe",
    "slug": "vibe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app_icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "vibe",
    "splash": {
      "image": "./assets/splash/splash_screen.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Fotoğraf çekmek ve paylaşmak için kamera erişimi gerekli.",
        "NSPhotoLibraryUsageDescription": "Galeriden fotoğraf seçmek için erişim gerekli."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.kemalp07.vibe"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#000000"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Gönderi paylaşmak için galeri erişimi gerekli.",
          "cameraPermission": "Fotoğraf çekmek için kamera erişimi gerekli."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Fotoğraf çekmek ve paylaşmak için kamera erişimi gerekli.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Son fotoğrafını göstermek ve galeriden seçmek için erişim gerekli.",
          "savePhotosPermission": "Fotoğrafları kaydetmek için erişim gerekli."
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "apiUrl": "http://localhost:8000",
      "router": {},
      "eas": {
        "projectId": "9e171425-1184-4344-a82a-0f89a248ace5"
      }
    }
  }
}
